{
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux",
  "model": "sonnet",
  "language": "Japanese",
  "permissions": {
    "allow": ["Bash(*)", "Read(**)", "Write(**/.claude/*)"],
    "deny": ["Bash(rm -rf *)", "Read(**/.env)"]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_create_issue.sh"
          }
        ]
      }
    ]
  }
}
