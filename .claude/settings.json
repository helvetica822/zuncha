{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**/.claude/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(**/.env)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_create_issue.sh"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false
  },
  "teammateMode": "tmux",
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
